      "parameters": {
        "jsCode": "const kw=[\"openai\",\"anthropic\",\"google\",\"microsoft\",\"aws\",\"deepmind\",\"gpt\",\"llm\",\"ai\",\"security\",\"automation\",\"cloud\",\"model\"];const items=$input.all().map(i=>i.json);const scored=items.map(it=>({...it,rs:(it.score||0)+kw.reduce((a,k)=>a+((it.title||\"\").toLowerCase().includes(k)?2:0),0)})).sort((a,b)=>b.rs-a.rs).slice(0,15);return scored.map(it=>({json:it}));"
      },
