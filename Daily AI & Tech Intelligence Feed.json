    {
      "parameters": {
        "jsCode": "const items = $input.all();\n\nlet subject = \"\";\nlet email = \"\";\n\nfor (const item of items) {\n  const raw = item.json.output?.[0]?.content?.[0]?.text || \"\";\n\n  try {\n    // remove markdown escaping issues\n    const cleaned = raw\n      .replace(/```json/g, \"\")\n      .replace(/```/g, \"\")\n      .trim();\n\n    const parsed = JSON.parse(cleaned);\n\n    subject = parsed.subject || \"\";\n    email = parsed.email || \"\";\n\n  } catch (e) {\n    // fallback extraction if JSON parse fails\n    const subjectMatch = raw.match(/\"subject\"\\s*:\\s*\"([^\"]+)\"/);\n    const emailMatch = raw.match(/\"email\"\\s*:\\s*\"([\\s\\S]*)\"/);\n\n    if (subjectMatch) subject = subjectMatch[1];\n    if (emailMatch) email = emailMatch[1];\n  }\n}\n\nreturn [\n  {\n    json: {\n      subject,\n      text: email\n    }\n  }\n];"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
